{
  "id": "staking-route-smoke",
  "title": "Staking route smoke",
  "route": "/staking",
  "severity": "critical",
  "tags": [
    "critical",
    "staking",
    "desktop"
  ],
  "viewports": [
    "desktop"
  ],
  "url": "http://localhost:8080/staking",
  "steps": [
    {
      "type": "debug_call",
      "method": "qaReset"
    },
    {
      "type": "navigate"
    },
    {
      "type": "wait_for_idle",
      "options": {
        "quietMs": 300,
        "timeoutMs": 5000
      }
    },
    {
      "type": "oracle",
      "name": "parity-element",
      "args": {
        "parityId": "staking-root"
      },
      "expect": {
        "present": true
      }
    },
    {
      "type": "wait_for_eval",
      "expression": "({ connectVisible: Boolean(document.querySelector('[data-role=\"staking-establish-connection\"]')), transferButtonCount: document.querySelectorAll('[data-role=\"staking-action-transfer-button\"]').length })",
      "expect": {
        "connectVisible": true,
        "transferButtonCount": 0
      },
      "timeoutMs": 4000,
      "pollMs": 100
    },
    {
      "type": "capture"
    }
  ]
}
