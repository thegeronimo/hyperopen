#!/usr/bin/env bb
;; Lookup shared command phrases from /hyperopen/command-phrases.edn.

(ns phrase.lookup
  (:require
   [clojure.edn :as edn]
   [clojure.java.io :as io]
   [clojure.pprint :as pprint]
   [clojure.string :as str]))

(def required-command-fields
  [:preconditions :steps :failure_policy :postconditions])

(defn normalize-alias [value]
  (->> (str/split (str/trim (str value)) #"\s+")
       (remove str/blank?)
       (str/join " ")
       (str/lower-case)))

(defn usage []
  (str "Usage: tools/phrase get \"<phrase>\"\n"
       "Example: tools/phrase get \"land the worktree\"\n"
       "Lookup: normalize phrase once, then :alias->id + :commands map lookups."))

(defn repo-root []
  (-> *file*
      io/file
      .getAbsoluteFile
      .getParentFile
      .getParentFile))

(defn fail [message exit-code]
  (binding [*out* *err*]
    (println (str "tools/phrase: " message)))
  exit-code)

(defn ensure-valid-command [command-id command]
  (when-not (string? command-id)
    (throw (ex-info "command ids under :commands must be strings" {})))
  (when-not (map? command)
    (throw (ex-info (str "command '" command-id "' must be a map") {})))
  (let [missing-fields (remove #(contains? command %) required-command-fields)]
    (when (seq missing-fields)
      (throw (ex-info (str "command '" command-id
                           " missing required field(s): "
                           (str/join ", " (map name missing-fields)))
                      {}))))
  (doseq [field required-command-fields]
    (let [value (get command field)]
      (when-not (and (sequential? value) (every? string? value))
        (throw (ex-info (str "command '" command-id
                             " field '" (name field)
                             "' must be a list of strings")
                        {}))))))

(defn ensure-valid-alias-entry [commands alias command-id]
  (when-not (string? alias)
    (throw (ex-info ":alias->id keys must be strings" {})))
  (when-not (= alias (normalize-alias alias))
    (throw (ex-info (str "alias key '" alias
                         "' must already be normalized (trimmed, single spaces, lowercase)")
                    {})))
  (when-not (string? command-id)
    (throw (ex-info (str "alias '" alias "' must map to a string command id") {})))
  (when-not (contains? commands command-id)
    (throw (ex-info (str "alias '" alias "' points to unknown command id '" command-id "'")
                    {}))))

(defn load-registry []
  (let [registry-path (io/file (repo-root) "command-phrases.edn")
        data (try
               (-> registry-path slurp edn/read-string)
               (catch java.io.FileNotFoundException _
                 (throw (ex-info (str "registry not found: " (.getPath registry-path)) {})))
               (catch Exception error
                 (throw (ex-info (str "invalid EDN in " (.getPath registry-path) ": "
                                      (.getMessage error))
                                 {}))))]
    (when-not (map? data)
      (throw (ex-info "registry root must be a map" {})))
    (when-not (= 2 (:schema-version data))
      (throw (ex-info "registry ':schema-version' must be 2" {})))
    (let [commands (:commands data)
          alias->id (:alias->id data)]
      (when-not (map? commands)
        (throw (ex-info "registry key ':commands' must be a map" {})))
      (when-not (map? alias->id)
        (throw (ex-info "registry key ':alias->id' must be a map" {})))
      (doseq [[command-id command] commands]
        (ensure-valid-command command-id command))
      (doseq [[alias command-id] alias->id]
        (ensure-valid-alias-entry commands alias command-id))
      {:commands commands
       :alias->id alias->id})))

(defn resolve-entry [registry phrase]
  (let [query (normalize-alias phrase)]
    (when-not (str/blank? query)
      (when-let [command-id (get (:alias->id registry) query)]
        (assoc (get (:commands registry) command-id) :id command-id)))))

(defn run-get [args]
  (if (empty? args)
    (fail (usage) 1)
    (let [phrase (str/join " " args)
          registry-result (try
                            {:registry (load-registry)}
                            (catch clojure.lang.ExceptionInfo error
                              {:error (.getMessage error)}))]
      (if-let [error-message (:error registry-result)]
        (fail error-message 1)
        (let [match (resolve-entry (:registry registry-result) phrase)]
          (if match
            (do
              (pprint/pprint match)
              0)
            (fail (str "no phrase match for '" phrase "'") 2)))))))

(defn -main [& args]
  (if (empty? args)
    (fail (usage) 1)
    (let [[command & rest-args] args]
      (case command
        "get" (run-get rest-args)
        (fail (usage) 1)))))

(System/exit (apply -main *command-line-args*))
