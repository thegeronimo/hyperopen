{:source-paths ["src" "test" "portfolio"]
 
 :dependencies [[no.cjohansen/portfolio "2026.03.1"]
                [coderafting/memsearch "0.1.1"]
                [no.cjohansen/replicant "2025.06.21"]
                [no.cjohansen/nexus "2025.07.1"]
                [org.clojure/test.check "1.1.1"]]
 
 :dev-http {8080 ["resources/public"]}
 
  :builds
 {:app {:target :browser
        :output-dir "resources/public/js"
        :asset-path "/js"
        :module-hash-names true
        :build-options {:manifest-name "manifest.json"}
        :module-loader true
        :modules {:main {:init-fn hyperopen.views.entrypoint/start!}
                  :trading_crypto {:entries [hyperopen.trading-crypto.module]
                                   :depends-on #{:main}}
                  :trade_chart {:entries [hyperopen.views.trading-chart.module]
                                :depends-on #{:main}}
                  :trading_indicators {:entries [hyperopen.views.trading-chart.indicators-module]
                                       :depends-on #{:trade_chart}}
                  :funding_modal {:entries [hyperopen.views.funding-modal-module]
                                  :depends-on #{:main}}
                  :spectate_mode_modal {:entries [hyperopen.views.spectate-mode-modal-module]
                                        :depends-on #{:main}}
                  :account_surfaces {:entries [hyperopen.views.account-surfaces-module]
                                     :depends-on #{:main}}
                  :portfolio_route {:entries [hyperopen.views.portfolio-view]
                                    :depends-on #{:account_surfaces}}
                  :leaderboard_route {:entries [hyperopen.views.leaderboard-view]
                                      :depends-on #{:main}}
                  :funding_comparison_route {:entries [hyperopen.views.funding-comparison-view]
                                             :depends-on #{:main}}
                  :staking_route {:entries [hyperopen.views.staking-view]
                                  :depends-on #{:main}}
                  :api_wallets_route {:entries [hyperopen.views.api-wallets-view]
                                      :depends-on #{:main}}
                  :vaults_route {:entries [hyperopen.views.vaults.list-view
                                           hyperopen.views.vaults.detail-view
                                           hyperopen.views.vaults.startup-preview]
                                 :depends-on #{:main}}}
        :devtools {:preloads [hyperopen.telemetry.console-preload]
                   :http-root "resources/public"
                   :http-port 8080
                   :after-load hyperopen.views.entrypoint/reload}}

  :portfolio {:target :portfolio
              :runner-ns hyperopen.workbench.runner
              :ns-regexp "-scenes$"
              :output-dir "resources/public/js"
              :asset-path "/js"
              :html-file {:path "resources/public/ui-workbench.html"
                          :title "Hyperopen UI Workbench"}
              :portfolio.ui/config {:css-paths ["/css/main.css"]
                                    :canvas-path "/ui-workbench-canvas.html"
                                    :viewport/defaults {:viewport/width "100%"
                                                        :viewport/height "100%"
                                                        :viewport/padding [20 20 20 20]}
                                    :viewport/options [{:title "Auto"
                                                        :value {:viewport/width "100%"
                                                                :viewport/height "100%"}}
                                                       {:title "iPhone 14 Pro Max"
                                                        :value {:viewport/width 430
                                                                :viewport/height 932}}
                                                       {:title "Tablet"
                                                        :value {:viewport/width 820
                                                                :viewport/height 1180}}
                                                       {:title "Desktop"
                                                        :value {:viewport/width 1440
                                                                :viewport/height 900}}]}}

  :portfolio-worker {:target :browser
                     :output-dir "resources/public/js"
                     :asset-path "/js"
                     :modules {:portfolio_worker {:init-fn hyperopen.portfolio.worker/init
                                                  :web-worker true}}
                     :compiler-options {:optimizations :advanced}}

  :vault-detail-worker {:target :browser
                        :output-dir "resources/public/js"
                        :asset-path "/js"
                        :modules {:vault_detail_worker {:init-fn hyperopen.vaults.detail.worker/init
                                                        :web-worker true}}
                     :compiler-options {:optimizations :advanced}}
  
  :test {:target :node-test
         :output-to "out/test.js"
         :ns-regexp "^(hyperopen\\.(?!websocket\\.).*-test|hyperopen\\.websocket\\.application\\..*-test|hyperopen\\.websocket\\.(active-asset-ctx|client|market-projection-runtime|orderbook|orderbook-policy|subscriptions-runtime|trades|trades-policy|user|webdata2)-test|hyperopen\\.websocket\\.(acl\\.hyperliquid|domain\\.(model|policy)|infrastructure\\.(runtime-effects|transport))-test|hyperopen\\.websocket\\.user-runtime\\..*-test)$"
         :compiler-options {:source-map true}
         :js-options {:resolve {"lightweight-charts" {:target :file
                                                      :file "test/shims/lightweight_charts_stub.cjs"}}}}

  :ws-test {:target :node-test
            :output-to "out/ws-test.js"
            :compiler-options {:source-map true}
            :ns-regexp "^(hyperopen\\.websocket\\..*-test|hyperopen\\.wallet\\.address-watcher-test|hyperopen\\.startup\\.runtime-test)$"}
  
  :release {:target :browser
            :output-dir "resources/public/js"
            :asset-path "/js"
            :module-hash-names true
            :build-options {:manifest-name "manifest.json"}
            :module-loader true
            :modules {:main {:init-fn hyperopen.views.entrypoint/start!}
                      :trading_crypto {:entries [hyperopen.trading-crypto.module]
                                       :depends-on #{:main}}
                      :trade_chart {:entries [hyperopen.views.trading-chart.module]
                                    :depends-on #{:main}}
                      :trading_indicators {:entries [hyperopen.views.trading-chart.indicators-module]
                                           :depends-on #{:trade_chart}}
                      :funding_modal {:entries [hyperopen.views.funding-modal-module]
                                      :depends-on #{:main}}
                      :spectate_mode_modal {:entries [hyperopen.views.spectate-mode-modal-module]
                                            :depends-on #{:main}}
                      :account_surfaces {:entries [hyperopen.views.account-surfaces-module]
                                         :depends-on #{:main}}
                      :portfolio_route {:entries [hyperopen.views.portfolio-view]
                                        :depends-on #{:account_surfaces}}
                      :leaderboard_route {:entries [hyperopen.views.leaderboard-view]
                                          :depends-on #{:main}}
                      :funding_comparison_route {:entries [hyperopen.views.funding-comparison-view]
                                                 :depends-on #{:main}}
                      :staking_route {:entries [hyperopen.views.staking-view]
                                      :depends-on #{:main}}
                      :api_wallets_route {:entries [hyperopen.views.api-wallets-view]
                                          :depends-on #{:main}}
                      :vaults_route {:entries [hyperopen.views.vaults.list-view
                                               hyperopen.views.vaults.detail-view
                                               hyperopen.views.vaults.startup-preview]
                                     :depends-on #{:main}}}
            :compiler-options {:optimizations :advanced}}}} 
