{
  "name": "hyperopen",
  "version": "0.1.0",
  "description": "ClojureScript app using Replicant",
  "scripts": {
    "cljs:watch": "shadow-cljs watch app",
    "dev": "concurrently -k -n TAILWIND,CLJS \"npm run css:watch\" \"npm run cljs:watch\"",
    "build": "npm run css:build && npx shadow-cljs release app",
    "repl": "npx shadow-cljs cljs-repl app",
    "test": "shadow-cljs compile test && node out/test.js",
    "lint:class-attrs": "node dev/check_class_attrs.mjs",
    "check": "npm run lint:class-attrs && npx shadow-cljs compile app && npx shadow-cljs compile test",
    "test:watch": "shadow-cljs watch test",
    "test:repl": "shadow-cljs cljs-repl test",
    "css:build": "tailwindcss -i ./src/styles/main.css -o ./resources/public/css/main.css --minify",
    "css:watch": "tailwindcss -i ./src/styles/main.css -o ./resources/public/css/main.css --watch"
  },
  "license": "AGPL-3.0",
  "dependencies": {
    "shadow-cljs": "^3.1.7",
    "lightweight-charts": "^5.0.8",
    "indicatorts": "^2.2.2"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.0",
    "daisyui": "^4.6.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0"
  }
}
